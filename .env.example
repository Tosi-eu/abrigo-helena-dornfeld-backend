# Copie para .env e preencha. No Docker Compose, DB_HOST/DB_PORT/REDIS_* são sobrescritos pelo compose.

DB_NAME=estoque
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
TEST_DB_NAME=estoque_test

PORT=3001
NODE_ENV=development

JWT_SECRET=<jwt_secret>
X_API_KEY=<x_api_key>
SUPERADMIN_APIKEY_IP_ALLOWLIST=127.0.0.1

REDIS_HOST=localhost
REDIS_PORT=6379


R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ASSETS_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_BUCKET_NAME=
R2_REGION=auto
ALLOW_MISSING_R2=0

SYSTEM_BACKUP_SKIP_R2_UPLOAD=false

ENABLE_TEMPORAL=true
ENABLE_CRON=true
TEMPORAL_ADDRESS=127.0.0.1:17233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=abrigo
NOTIFICATION_BOOTSTRAP_CRON=*/30 * * * *

IMPORT_UPLOAD_DIR=/var/lib/abrigo-imports

PUBLIC_APP_URL=http://localhost
PUBLIC_DEFAULT_LOGO_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

INVITE_TOKEN_PEPPER=

CONTRACT_CODE_PEPPER=


LOG_HTTP_TENANT=false

SKIP_PRISMA_SCHEMA_SYNC=0
PRISMA_AUTO_BASELINE=0
PRISMA_COMPAT_LEGACY_LOGIN_UNIQUE=1

PRICING_API_KEY=
PRICING_BASE_URL=
PRICING_SEARCH_DOCKER_HOST=
PRICING_DISABLE_DOCKER_HOST_REMAP=0
