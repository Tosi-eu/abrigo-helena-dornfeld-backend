{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@abrigo/sdk": ["./node_modules/@abrigo/sdk/dist/index.d.ts"]
    }
  },
  "include": [
    "src",
    "src/infrastructure"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}