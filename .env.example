# Banco de dados
DB_NAME=<database_name>
DB_USER=<database_user>
DB_PASSWORD=<database_password>
DB_HOST=<database_host>
DB_PORT=<database_port>
STOKIO_DATABASE_URL=postgresql://<database_user>:<database_password>@<database_host>:<database_port>/<database_name>?schema=public

PRISMA_AUTO_BASELINE=1

JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=<jwt_expires_in>

REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>

LOG_FORMAT=pretty  
LOG_LEVEL=debug   
LOG_HTTP_TENANT=1 

PUBLIC_TENANT_RATE_WINDOW_MS=60000
PUBLIC_TENANT_LIST_MAX=120
PUBLIC_TENANT_BRANDING_MAX=120

# X_API_KEY=

# SUPERADMIN_APIKEY_IP_ALLOWLIST=127.0.0.1,172.18.0.1

# API de preços (Uprising / referência). Sem URL+chave, o backfill e o botão "Forçar busca" devolvem 503.
# Se o backend corre em Docker e a API de preços está na máquina (fora do container), use:
#   PRICING_API_URL=http://host.docker.internal:3010
# (não use 127.0.0.1: o 127.0.0.1 dentro do container é o próprio container.)
# Se o `docker compose` não carregar backend/.env, o serviço backend no compose inclui `../backend/.env`.
# PRICING_API_URL=http://127.0.0.1:3010
# PRICING_API_KEY=
#
# Agendador de backfill: corre na API Price Search; o backend só expõe POST interno.
# Defina o mesmo segredo no serviço price-search (INTERNAL_PRICE_BACKFILL_SECRET).
# INTERNAL_PRICE_BACKFILL_SECRET=

# Jobs (backfill quando o endpoint interno é chamado)
# ENABLE_PRICE_BACKFILL_CRON=true
# PRICE_BACKFILL_BATCH=40
# PRICE_BACKFILL_MAX_PER_TENANT=80
# Pausa entre cada chamada à API de preços (evita rajadas / rate limit)
# PRICE_BACKFILL_INTER_REQUEST_DELAY_MS=300
# Após "Forçar busca" no painel: cooldown por tenant (Redis recomendado em produção)
# PRICE_BACKFILL_MANUAL_COOLDOWN_SEC=1800
# PRICE_BACKFILL_MANUAL_COOLDOWN_ON_ERROR_SEC=120

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ASSETS_BUCKET_NAME=porto-assets
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# R2_REGION=auto

# R2_BUCKET_NAME=abrigo-helena-dornfeld

# IMPORT_BIRTH_DATE_FALLBACK=1970-01-01
