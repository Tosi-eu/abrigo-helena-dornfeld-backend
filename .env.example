# Banco de dados
DB_NAME=<database_name>
DB_USER=<database_user>
DB_PASSWORD=<database_password>
DB_HOST=<database_host>
DB_PORT=<database_port>

JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=<jwt_expires_in>

REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>

# LOG_FORMAT=pretty  → logs legíveis em produção (padrão: JSON)
# LOG_LEVEL=debug    → nível de log (padrão prod: info)
# LOG_HTTP_TENANT=1  → log info por pedido com tenant+user (ver docs/TENANT-MULTI.md)

# Rate limit endpoints públicos GET /tenants e GET /tenants/:slug/branding (janela em ms; máx. por janela)
# PUBLIC_TENANT_RATE_WINDOW_MS=60000
# PUBLIC_TENANT_LIST_MAX=120
# PUBLIC_TENANT_BRANDING_MAX=120

# Código de contrato (cadastro público): pepper opcional concatenado ao código antes do hash (defesa em vazamento de DB)
# CONTRACT_CODE_PEPPER=

# X_API_KEY=

# Microsserviço porto-api-price-search. Em Docker: PRICING_API_URL=http://porto-api-price-search:3010
# PRICING_API_URL=
# PRICING_API_KEY=

# --- Cloudflare R2 (uma conta; dois buckets com o mesmo par de chaves) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_REGION=auto

# Bucket de backups (dump Postgres) — usado pelo serviço backup/backup.sh
# R2_BUCKET_NAME=abrigo-helena-dornfeld

# Bucket de assets públicos (logos dos abrigos) — backend faz PutObject aqui
# R2_ASSETS_BUCKET_NAME=porto-assets
# URL pública desse bucket (domínio R2 ou custom), sem barra no fim — deve bater com as URLs servidas no <img>
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# Envie também default_logo.png na raiz do bucket (fallback da UI; mesmo ficheiro que frontend/public/default_logo.png).

# Cache em memória (ListObjects ao resolver logo por slug sem logo_url na BD). Padrão 600000 ms (10 min). 0 = desliga.
# R2_LOGO_LIST_CACHE_TTL_MS=
