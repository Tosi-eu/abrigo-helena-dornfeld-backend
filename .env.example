# Banco de dados
DB_NAME=<database_name>
DB_USER=<database_user>
DB_PASSWORD=<database_password>
DB_HOST=<database_host>
DB_PORT=<database_port>

# URL PostgreSQL usada pelo Prisma (prisma/schema.prisma → datasource db).
# Deve ser o MESMO banco que DB_* acima (mesmo host, porta, utilizador, senha e nome da base).
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DA_BASE?schema=public
# Senha ou utilizador com caracteres especiais: codifique em URL (ex.: @ → %40, : → %3A).
# Exemplo local: postgresql://postgres:postgres@localhost:5432/estoque?schema=public
# Exemplo Docker (rede compose, serviço postgres): postgresql://postgres:postgres@postgres:5432/estoque?schema=public
STOKIO_DATABASE_URL=postgresql://<database_user>:<database_password>@<database_host>:<database_port>/<database_name>?schema=public

# Docker: se migrate deploy falhar com P3005 (base já com tabelas sem histórico Migrate), o compose pode definir PRISMA_AUTO_BASELINE=1.
# PRISMA_AUTO_BASELINE=1

JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=<jwt_expires_in>

REDIS_HOST=<redis_host>
REDIS_PORT=<redis_port>

# LOG_FORMAT=pretty  → logs legíveis em produção (padrão: JSON)
# LOG_LEVEL=debug    → nível de log (padrão prod: info)
# LOG_HTTP_TENANT=1  → log info por pedido com tenant+user (ver docs/TENANT-MULTI.md)

# Rate limit endpoints públicos GET /tenants e GET /tenants/:slug/branding (janela em ms; máx. por janela)
# PUBLIC_TENANT_RATE_WINDOW_MS=60000
# PUBLIC_TENANT_LIST_MAX=120
# PUBLIC_TENANT_BRANDING_MAX=120

# Código de contrato (cadastro público): pepper opcional concatenado ao código antes do hash (defesa em vazamento de DB)
# CONTRACT_CODE_PEPPER=
# Códigos de contrato podem ter e-mail reservado em `contract_portfolio.bound_login` (API: bound_login com contract_code).

# Chave para rotas admin via header X-API-Key (gestão de tenants, etc.).
# X_API_KEY=
#
# Opcional: lista separada por vírgulas de IPs que podem usar X-API-Key (ex.: 172.18.0.1 atrás do Docker).
# Se vazio ou omitido, não há restrição por IP — apenas a chave é validada.
# SUPERADMIN_APIKEY_IP_ALLOWLIST=127.0.0.1,172.18.0.1

# Microsserviço porto-api-price-search (obrigatório para preenchimento automático de preço ao criar medicamento/insumo).
# Sem URL+chave, o backend ignora a busca mesmo com "Busca automática de preços" ligada no painel.
#
# Docker Compose (backup/docker-compose.yml): o backend recebe PRICING_API_URL=http://porto-api-price-search:3010
# automaticamente; defina PRICING_API_KEY na .env da raiz (ou use o valor dev por defeito do compose).
#
# Backend a correr no host (npm run dev): use o porto exposto em localhost, ex.:
# PRICING_API_URL=http://127.0.0.1:3010
# PRICING_API_KEY=

# --- Cloudflare R2 (uma conta; dois buckets com o mesmo par de chaves) ---
# Obrigatórias para o arranque e para POST /api/v1/tenant/branding/logo (sem isto: exit 1 ou 503 se ALLOW_MISSING_R2=1):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ASSETS_BUCKET_NAME=porto-assets
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# R2_REGION=auto

# R2_BUCKET_NAME=abrigo-helena-dornfeld

# URL pública do bucket de assets, sem barra no fim — deve bater com as URLs servidas no <img>
# Envie também default_logo.png na raiz do bucket (fallback da UI; mesmo ficheiro que frontend/public/default_logo.png).

# Sem as variáveis R2 acima, a aplicação termina ao arrancar (exit 1), para o Docker não ficar com serviço “meio morto”.
# Apenas desenvolvimento local sem Cloudflare: ALLOW_MISSING_R2=1 (upload de logo continua a responder 503).
# ALLOW_MISSING_R2=

# Cache em memória (ListObjects ao resolver logo por slug sem logo_url na BD). Padrão 600000 ms (10 min). 0 = desliga.
# R2_LOGO_LIST_CACHE_TTL_MS=
